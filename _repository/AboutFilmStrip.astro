---
import { Picture } from 'astro:assets';

import { aboutFilmStripFrames } from '@/data/about';
import MotionPath from '@/components/UI/MotionPath.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;



const sectionClass =
  '-mx-[min(1.25rem,5vw)] py-2 xl:-mx-[min(5rem,8vw)]';
const sprocketClass =
  'h-3.5 border-y border-white/5 bg-[radial-gradient(circle_at_50%_50%,transparent_4px,#141414_4.5px)] bg-[length:20px_14px] bg-repeat-x bg-[position:10px_50%]';
 const frameClass =
  'absolute w-[clamp(140px,38vw,220px)] shrink-0 border-x border-white/12 bg-black shadow-[0_12px_40px_rgba(0,0,0,0.45)]';
const imgClass = 'block aspect-[3/2] h-auto w-full object-cover';

/** GSAP MotionPath 用。形状は後から d だけ差し替えて調整可能 */
const curveSvgClass =
  'pointer-events-none absolute inset-x-0 top-1/2 z-0 h-[min(320px,55vw)] w-full -translate-y-1/2 text-white/15';
---

<section class:list={["relative overflow-visible h-[min(320px,55vw)]", sectionClass, className]} data-about-film-strip>
    <MotionPath class={curveSvgClass} elementId="about-film-curve"/>

    {aboutFilmStripFrames.map((frame) => (
      <div class={frameClass} data-film-frame>
        <div class={sprocketClass} aria-hidden="true"></div>
        <Picture
            src={frame.src}
            alt={frame.alt}
            width={360}
            height={240}
            formats={['avif', 'webp']}
            class={imgClass}
        />
        <div
          class:list={[sprocketClass, 'rotate-180']}
          aria-hidden="true"
        ></div>
      </div>
    ))}
</section>


