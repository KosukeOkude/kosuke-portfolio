---
interface MotionPathProps {
  class?: string;
  elementId?: string;
}

const { class:className = '',  elementId } = Astro.props as MotionPathProps
---

<svg
class={className}
viewBox="0 0 1200 280"
preserveAspectRatio="none"
aria-hidden="true"
>
    <path
    id={elementId}
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    vector-effect="non-scaling-stroke"
    d="M -60 200 C 380 72, 820 72, 1260 200"
    />
</svg>