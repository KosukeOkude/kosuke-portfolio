---
import { displayEntranceFilms } from '@/sanity/site-settings'
const sprocketClass =
  'sprocket h-3.5 border-y border-white/5 bg-[radial-gradient(circle_at_50%_50%,transparent_4px,#141414_4.5px)] bg-[length:20px_14px] bg-repeat-x bg-[position:10px_50%]';

const films = await displayEntranceFilms();

---

<div data-entrance-root class="fixed inset-0 z-[9999] overflow-hidden">
  <!-- 背景ビューポート -->
  <div data-entrance-bg class="absolute inset-0 w-dvw h-dvh bg-black"></div>

    <!-- グリッド線（カメラファインダー風） -->
  <!-- 縦線 1/3 -->
  <div data-entrance-grid-v1 class="opacity-0 absolute top-0 bottom-0 left-1/3 w-px bg-white/20"></div>
  <!-- 縦線 2/3 -->
  <div data-entrance-grid-v2 class="opacity-0 absolute top-0 bottom-0 left-2/3 w-px bg-white/20"></div>
  <!-- 横線 1/3 -->
  <div data-entrance-grid-h1 class="opacity-0 absolute left-0 right-0 top-1/3 h-px bg-white/20"></div>
  <!-- 横線 2/3 -->
  <div data-entrance-grid-h2 class="opacity-0 absolute left-0 right-0 top-2/3 h-px bg-white/20"></div>

  <!-- 中央テキスト -->
  <div data-entrance-title class="opacity-0 absolute z-[9999] inset-0 flex flex-col items-center justify-center gap-3 pointer-events-none">
    <p class="font-body text-xs tracking-[0.3em] text-white/60">Welcome to</p>
    <h1 class="font-accent text-2xl font-bold tracking-widest text-white text-center md:text-5xl">Kosuke's Portfolio</h1>
  </div>

  {films.map((film) => (
    <div data-entrance-film class='absolute opacity-0 grayscale w-[100px] md:w-[160px] shrink-0 border-x border-white/12 bg-black shadow-[0_12px_40px_rgba(0,0,0,0.45)]' data-film-frame>
      <div class={sprocketClass} aria-hidden="true"></div>
      <img
          src={film.url}
          alt=""
          width={360}
          height={240}
          class="block aspect-[3/2] h-auto w-full object-cover"
      />
      <div
        class:list={[sprocketClass, 'rotate-180']}
        aria-hidden="true"
      ></div>
    </div>
  ))}
  <span data-entrance-tooltip class="z-[9999] absolute pointer-events-none opacity-0 -translate-x-1/2 -translate-y-3 transition-opacity duration-200 bg-white/15 backdrop-blur-md text-white text-[11px] tracking-[0.18em] px-3 py-1.5 rounded-full border border-white/20 whitespace-nowrap">
    grab me✦
  </span>

</div>


