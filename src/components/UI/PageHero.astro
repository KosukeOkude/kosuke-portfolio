---
interface Props{
    label: string;
    title?: string;
    tagline?: string;
}

const { label, title, tagline } = Astro.props;
---

<div
  class="relative flex min-h-dvh w-full flex-col justify-end pb-12 md:pb-20"
>
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent pointer-events-none"
      aria-hidden="true"
    ></div>
    <div
      class="relative z-10 mx-auto w-full max-w-[1680px] px-5 xl:px-20"
    >
        <div class="relative z-10 max-w-xl" data-reveal>
            <p
                class="mb-2 text-[0.65rem] font-semibold uppercase tracking-[0.3em] text-white/60 md:text-[0.7rem]"
            >
                {label}
            </p>
            <h1
                class="font-accent text-sm md:text-3xl font-bold leading-tight tracking-[0.04em] text-[var(--color-white)] md:text-4xl lg:text-5xl"
            >
                {title}
            </h1>
            <p class="mt-1 text-[10px] text-white/80 md:text-base">
                {tagline}
            </p>
            <p
                class="relative z-10 mt-12 text-[10px] uppercase tracking-[0.25em] text-white/40"
                aria-hidden="true"
            >
                Scroll
            </p>
        </div>
    </div>
</div>