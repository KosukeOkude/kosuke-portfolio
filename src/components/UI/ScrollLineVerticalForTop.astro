---
type ScrollLineVerticalForTopOptions = {
    isHiddenText?: boolean;
    isColumn?: boolean;
}
const { isHiddenText = false } = Astro.props as ScrollLineVerticalForTopOptions
---
<!-- スクロール誘導ライン -->
<div class=`scroll-indicator absolute bottom-10 left-1/2 -translate-x-1/2 pointer-events-none flex items-center gap-2 flex-col`>
    <span class=`font-body text-[0.6rem] tracking-[0.3em] uppercase text-white/40`>{ isHiddenText ? '' : 'Scroll'}</span>
    <div class="scroll-line scroll-line-horizontal"></div>
</div>
