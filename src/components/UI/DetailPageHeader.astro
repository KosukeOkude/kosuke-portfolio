---
interface Props {
    label: string;
    title: string;
    date?: string;
    category?: string;
    tags?: string[] ;
    description?: string;
}

const { label, title, date, category, tags = [], description } = Astro.props;

---



<header class="border border-white/15 bg-white/5 backdrop-blur-md rounded-lg p-4 md:p-6 space-y-4" data-reveal-once>
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
      <div>
        <p class="text-[10px] md:text-xs uppercase tracking-[0.25em] text-white/50 mb-2">
          { label }
        </p>
        <h1
          class="
            font-accent font-semibold
            text-base md:text-2xl lg:text-[26px]
            leading-snug
            text-white
          "
        >
          { title }
        </h1>
        {
            date && (
            <p
                class="
                    mt-3
                    text-[11px] md:text-xs
                    tracking-[0.16em] uppercase
                    text-white/60
                "
                >
                Date { date } ・ Category { category }
            </p>
            )
        }
      </div>

      { tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          { tags.map((tag) => (
            <span class="text-[8px] md:text-xs px-3 py-1 rounded-full border border-white/25 bg-white/10">
              { tag }
            </span>
          ))}
        </div>
      )}
    </div>
    {
        description && (
        <p class="text-xs md:text-base text-white/80 leading-relaxed">
            { description }
        </p>
        )
    }
  </header>