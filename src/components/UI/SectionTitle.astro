---

interface SectionTitleProps {
  title: string;
  revealOnce?: boolean;
}

const { title, revealOnce = false } = Astro.props as SectionTitleProps;
---


<div
  class="w-fit"
  data-reveal-enter={revealOnce ? undefined : true}
  data-reveal-once={revealOnce ? true : undefined}
>
    <h2
    class="
      font-accent font-semibold
      text-[28px] md:text-[40px] lg:text-[44px]
      tracking-[0.18em] uppercase
      text-[var(--color-white)]
      inline-block mb-3
      "
  >
    {title}
  </h2>
  <p
    class="
      font-body
      text-[12px] md:text-[14px]
      leading-relaxed
      text-white/70
      max-w-[32rem]
      hidden min-[390px]:block
      "
  >
  <slot/>
  </p>
</div>