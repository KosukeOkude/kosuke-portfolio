---
interface Props {
    label: string;
    href: string;
}

const { label, href } = Astro.props;
---

<div class="flex items-center justify-between text-xs md:text-sm text-white/60 pt-4 border-t border-white/10" data-reveal>
    <a href={ href } class="hover:text-white transition-colors">
    ← Back to { label }
    </a>
    <a href="#top" class="hover:text-white transition-colors">
    Back to top ↑
    </a>
</div>