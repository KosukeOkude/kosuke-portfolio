---

import SectionLayout from "@/components/Layout/SectionLayout.astro";
import SectionTitle from "@/components/Layout/SectionTitle.astro";
import WorksCardSlider from "@/components/Works/WorksCardSlider.astro";
import BackgroundSection from '@/components/Layout/BackgroundSection.astro';

import worksBackgroundImage from '@/assets/images/works-background-img.jpg'
import { type WorkForClient } from "@/data/works";
interface Props {
    works: WorkForClient[];
}

const {works} = Astro.props;
---


<BackgroundSection image={worksBackgroundImage} alt=""
>
    <SectionLayout>
        <div class="z-20 flex-1 flex flex-col justify-between max-h-[900px] my-auto" slot="sectionContent">
        <!-- 縦の flex ＋ justify-between に変更 -->
            <!-- 上側：タイトル -->
            <SectionTitle title="WORKS">
            Step into my world through selected works.<br>
            —or an intimate collection of moments across genres.
            </SectionTitle>
            <!-- 下側：案内文＋スライダーをラッパーでひとまとめ -->
            <div>
            <!-- 上下スクロール案内 -->
            <p class="text-[var(--color-white)] text-sm mb-2">
                上下スクロールで作品が流れます
            </p>
            <!-- カードスライダー用ラッパー（横スクロール） -->
                <WorksCardSlider works={works}/>
            </div>
        </div>
        <a
        class="flex-shrink-0 flex text-[var(--color-white)] text-base md:text-xl font-bold"
        slot="sectionCta"
        href="/works"
        >
        View all works
        </a>
    </SectionLayout>
</BackgroundSection>