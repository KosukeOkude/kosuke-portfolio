---
import BackgroundSection from '@/components/Layout/BackgroundSection.astro';
import SectionLayout from '@/components/Layout/SectionLayout.astro';
import SectionTitle from '@/components/UI/SectionTitle.astro';
import SectionCtaLink from '@/components/UI/SectionCtaLink.astro';

import GalleryCategoryGrid from '@/components/Gallery/GalleryCategoryGrid.astro';
import { galleryPageConfig } from '@/data/gallery';
import type { GalleryCategory } from '@/data/gallery';

interface Props {
    galleryCategories: GalleryCategory[];
}

const { galleryCategories } = Astro.props;
---


<BackgroundSection image={ galleryPageConfig.backgroundImage } alt={galleryPageConfig.backgroundAlt} showOverlay={ false }>
    <SectionLayout>
        <div class="z-20 flex-1 flex flex-col justify-between my-auto gap-10" slot="sectionContent">
        <!-- 縦の flex ＋ justify-between に変更 -->
            <!-- 上側：タイトル -->
            <SectionTitle title="GALLERY">
                Photographs and moments, collected over time.
            </SectionTitle>
            <GalleryCategoryGrid
                galleryCategories={ galleryCategories }
                slot="sectionContent"
            />
        </div>
        <SectionCtaLink
            slot="sectionCta"
            href="/gallery"
            label="More photographs"
        />
    </SectionLayout>
</BackgroundSection>