---
import type { GalleryCategory } from '@/data/gallery';

interface Props {
    galleryCategories: GalleryCategory[];
}

const { galleryCategories } = Astro.props;

---

<div
  class="
    grid
    grid-cols-1 sm:grid-cols-2 lg:grid-cols-3
    gap-4 md:gap-6
  "
  data-reveal-each>
    {galleryCategories.map(category => (
        <a href={`/gallery/${category.slug}`}
           class="
            group
            relative
            block
            overflow-hidden
            bg-black/10
        ">
            <img
                src={category.imageUrl}
                alt={category.imageAlt}
                loading="lazy"
                class="
                    w-full
                    aspect-[4/3]
                    object-cover
                    transition-transform
                    duration-500
                    group-hover:scale-[1.03]
            "/>
            <div
                class="
                absolute inset-x-0 bottom-0
                px-4 py-3
                bg-gradient-to-t from-black/70 via-black/40 to-transparent
                "
            >
                <span
                    class="
                        inline-block
                        font-accent
                        text-sm md:text-base
                        text-white
                ">
                    {category.title}
                </span>
            </div>
            <span
                class="
                    absolute inset-0
                    ring-1 ring-white/0
                    group-hover:ring-white/40
                    transition
                    "
                aria-hidden="true">
            </span>
        </a>
    ))}
</div>