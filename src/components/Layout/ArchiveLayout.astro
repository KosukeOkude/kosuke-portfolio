---
interface Props {
    extraClass?: string;
}

const { extraClass, ...rest } = Astro.props as Props;
---

<div class=`overflow-hidden relative min-h-svh text-[var(--color-white)] ${extraClass}` {...rest}>
    <main class="relative max-w-[1680px] my-auto mx-auto px-5 xl:px-20 pt-24 pb-20 md:pb-30 space-y-5">
        <slot/>
    </main>
</div>
