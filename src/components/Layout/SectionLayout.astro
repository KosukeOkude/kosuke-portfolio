---
const {addClass, ...rest} = Astro.props;
---


<section {...rest} class=` relative z-20 flex h-full w-full flex-col px-5 pt-[60px] min-[390px]:pt-16 xl:px-20 xl:pt-[80px] ${addClass ?? 'pb-[40px]'}`>
    <div class="flex-1 flex flex-col max-w-[1680px] mx-auto w-full">
        <slot name="sectionContent" />
      </div>
      <div class="flex-shrink-0 flex justify-center mt-6 min-[390px]:mt-8">
        <slot name="sectionCta" />
      </div>
 </section>