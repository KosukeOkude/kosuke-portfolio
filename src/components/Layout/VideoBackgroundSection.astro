---
interface Props {
  videoSrc?: string;
  alt: string;
  className?: string;
  pcVideoPoster?: string;
  pcVideoSrcWebm?: string;
  pcVideoSrcMp4?: string;
  mobileVideoSrcWebm? :string;
  mobileVideoSrcMp4? :string;
}

const {
  videoSrc,
  pcVideoSrcWebm,
  pcVideoSrcMp4,
  mobileVideoSrcWebm,
  mobileVideoSrcMp4,
  pcVideoPoster,
  alt,
  className,
  ...rest
} = Astro.props as Props & Record<string, unknown>;

const hasSources = Boolean(pcVideoSrcWebm || pcVideoSrcMp4);
const fallbackSrc = videoSrc ?? '';
---

<section
  class={["relative min-h-svh", className].filter(Boolean).join(" ")}
  {...rest}
>
  <div class="absolute inset-0 -z-20" data-hero-bg-parallax>
    {/* 背景動画。object-cover で領域に合わせる */}
    <video
      data-video-bg
      {...(!hasSources && fallbackSrc ? { src: fallbackSrc } : {})}
      poster={pcVideoPoster}
      muted
      autoplay
      loop
      playsinline
      preload="metadata"
      aria-label={alt}
      class="w-full h-full object-cover"
    >
      {hasSources && (
        <>
          {pcVideoSrcWebm && <source data-src={pcVideoSrcWebm} data-pc-movie type="video/webm" />}
          {pcVideoSrcMp4 && <source data-src={pcVideoSrcMp4} data-pc-movie type="video/mp4" />}
          {mobileVideoSrcWebm && <source data-src={mobileVideoSrcWebm} data-mobile-movie type="video/webm" />}
          {mobileVideoSrcMp4 && <source data-src={mobileVideoSrcMp4} data-mobile-movie type="video/mp4" />}
        </>
      )}
    </video>

    {/* 動画が再生できない/読み込み前のフォールバック */}
    <div class="absolute inset-0 -z-10 bg-black" aria-hidden="true" />
  </div>

  <slot />
</section>

<script>
  const isMobile = window.matchMedia("(max-width: 767px)").matches;
  const mobileMovieData = document.querySelectorAll('[data-mobile-movie]');
  const pcMovieData = document.querySelectorAll('[data-pc-movie]');
  if(isMobile && mobileMovieData.length > 0){
    mobileMovieData.forEach((source) => {
      const sourceEl = source as HTMLSourceElement;
      sourceEl.src = sourceEl.dataset.src ?? '';
    })}else{
      pcMovieData.forEach((source) => {
        const sourceEl = source as HTMLSourceElement;
        sourceEl.src = sourceEl.dataset.src ?? '';
    })
  }

  const video = document.querySelector('[data-video-bg]') as HTMLVideoElement;
  if(video){
    video.load();
    video.addEventListener('canplay', () => {
      video.play().catch(() => {})
    }, {once: true})
  }
</script>