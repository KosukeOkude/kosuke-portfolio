---
import { displayAboutAnimationImages } from '@/sanity/site-settings';

const SIZE_CLASS: Record<string, string> = {
  sm: 'w-[120px] md:w-[280px]',
  md: 'w-[180px] md:w-[450px]',
  lg: 'w-[240px] md:w-[600px]',
};

const images = await displayAboutAnimationImages();
---

<div class="overflow-hidden absolute w-full h-full">
  {images.map((image) => (
    <div class={`shrink-0 round-xs overflow-hidden ${SIZE_CLASS[image.size] ?? SIZE_CLASS.md}`}
        data-about-images>
      <img
        src={image.url}
        alt=""
        class="h-full w-full object-cover block"
      />
    </div>
  ))}
</div>
