---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BackgroundSection from '@/components/Layout/BackgroundSection.astro';
import Breadcrumbs from '@/components/UI/Breadcrumbs.astro';
import ArchiveLayout from '@/components/Layout/ArchiveLayout.astro';
import ArchivePageHeader from '@/components/UI/ArchivePageHeader.astro';

import { getAllWorks, worksPageConfig } from '@/data/works';
import { WorksArchiveSection } from '@/components/Works/WorksArchiveSection';
import ScreenOverlay from '@/components/UI/ScreenOverlay.astro';

const workForClient = await getAllWorks();

---




<BaseLayout>
  <BackgroundSection image={worksPageConfig.backgroundImage} alt={worksPageConfig.backgroundAlt} mobileImage={worksPageConfig.mobileImage} works-archive-root eager>
      <ScreenOverlay/>
      <ArchiveLayout>
        <Breadcrumbs items={[{label: 'Works'}]}/>
        <!-- タイトルエリア -->
        <ArchivePageHeader
          label="works"
          title="works &amp; archives"
        >
        Client commissions and personal work, documented.
        </ArchivePageHeader>
        <div id="archive-main">
          <WorksArchiveSection works={workForClient} client:load/>
        </div>
      </ArchiveLayout>

  </BackgroundSection>
</BaseLayout>

