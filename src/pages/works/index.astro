---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BackgroundSection from '@/components/Layout/BackgroundSection.astro';

import { getAllWorks, worksPageConfig } from '@/data/works';
import { WorksArchiveSection } from '@/components/Works/WorksArchiveSection';
import ArchivePageHeader from '@/components/UI/ArchivePageHeader.astro';
import Breadcrumbs from '@/components/UI/Breadcrumbs.astro';

const workForClient = await getAllWorks();

---




<BaseLayout>
  <BackgroundSection image={worksPageConfig.backgroundImage} alt={worksPageConfig.backgroundAlt} showOverlay={true}
>
    <div class="relative min-h-screen text-[var(--color-white)]">

        <main class="max-w-[1440px] mx-auto px-4 md:px-8 lg:px-16 py-10 md:py-14 space-y-10">
          <Breadcrumbs
          items={[
            {label: 'Works'}
          ]}>
        </Breadcrumbs>
          <!-- タイトルエリア -->
           <ArchivePageHeader
            label="works"
            title="Selected works &amp; archives"
          >
          A quiet record of client work and personal projects.
          </ArchivePageHeader>
          <WorksArchiveSection
            works={workForClient}
            client:load/>
        </main>
      </div>
    </BackgroundSection>
  </BaseLayout>