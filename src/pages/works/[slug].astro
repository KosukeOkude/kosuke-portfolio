---
import type { GetStaticPaths } from "astro";
import Breadcrumbs from "@/components/UI/Breadcrumbs.astro";
import BaseLayout from '@/layouts/BaseLayout.astro';
import DetailPageHeader from "@/components/UI/DetailPageHeader.astro";
import LabeledSection from "@/components/UI/LabeledSection.astro";
import MoreInCategory from "@/components/UI/MoreInCategory.astro";

import { getAllWorks,getWorkBySlug } from '@/data/works';
import PageBottomNav from "@/components/UI/PageBottomNav.astro";



export const getStaticPaths = (async () => {
  const works = await getAllWorks();
    return works.map((work) => ({
      params:{ slug: work.slug.trim().toLowerCase()}
    }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
const work = await getWorkBySlug(slug as string);

const allWorks = await getAllWorks();
// カテゴリ一覧（'All' + 小文字カテゴリの Set）
const categorySet = new Set(allWorks.map(w => w.category))
const allCategories = ['All', ...categorySet];

if(!work){
  throw new Error(`Work not found for slug: ${slug}`);
}
---


<BaseLayout>
  <div class="min-h-screen bg-black text-[var(--color-white)]">
    <div class="max-w-5xl mx-auto px-4 md:px-8 lg:px-12 py-10 md:py-16 space-y-10">
      <Breadcrumbs
      items={[
        {label: 'Works', href: "/works"},
        {label: work.title }
      ]}/>

      <DetailPageHeader
        label="Work detail"
        title={work.title}
        date={work.date}
        category={work.category}
        tags={work.tags}
        description={work.description}
      />

      <!-- Main visual & sub images -->
      <section class="space-y-4">
        <!-- Main image -->
        <div class="overflow-hidden rounded-lg border border-white/15 bg-white/5 max-h-[560px]">
          <img
            src={work.thumbnail}
            alt={work.thumbnailAlt}
            class="w-full h-full max-h-[560px] object-cover"
            loading="lazy"
          />
        </div>

        <!-- Sub image placeholders -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {work.subImage && work.subImage.length > 0 && work.subImage.map(image =>
            <div class="aspect-video rounded-md overflow-hidden border border-white/15 bg-white/5">
            <img
            src={image.src}
            alt={image.alt}
            class='h-full w-full object-cover'
            loading="lazy"
            />
          </div>
        )
        }
        </div>
      </section>

      <section class="space-y-10 text-sm md:text-base leading-relaxed">
        {work.concept && (
          <LabeledSection
            label="Concept">
              <p class="text-white/80">{work.concept}</p>
          </LabeledSection>
        )}

        {work.process && (
          <LabeledSection
            label="Process">
              <p class="text-white/80">{work.process}</p>
          </LabeledSection>
        )}

        {work.role && (
          <LabeledSection
            label="ROLE">
              {work.role && work.role.length > 0 && (
                <ul class="text-white/80 list-disc list-inside space-y-1">
                  {work.role.map((r) => <li>{r}</li>)}
                </ul>
              )}
          </LabeledSection>
        )}

        {work.notes && (
          <LabeledSection
            label="NOTES"
          >
            <p class="text-white/80">{work.notes}</p>
          </LabeledSection>
        )}

        {work.credits && (
          <LabeledSection
            label="CREDITS"
          >
          {work.credits && work.credits.length > 0 && (
            <ul class="text-white/80 space-y-1">
              {work.credits.map((c) => <li>{c.label} : {c.value}</li>)}
            </ul>
          )}
          </LabeledSection>
        )}
      </section>

      <MoreInCategory
        baseHref="/works"
        allCategories={allCategories}
      />

      <PageBottomNav
        label="works"
        href="/works"
      />
    </div>
  </div>
</BaseLayout>