---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/UI/Breadcrumbs.astro';
import ArchivePageHeader from '@/components/UI/ArchivePageHeader.astro';
import ArchiveLayout from '@/components/Layout/ArchiveLayout.astro';
import BackgroundSection from '@/components/Layout/BackgroundSection.astro';
import { getGalleryCategories, galleryPageConfig } from '@/data/gallery';
import GalleryCategoryGrid from '@/components/Gallery/GalleryCategoryGrid.astro';
import ScreenOverlay from '@/components/UI/ScreenOverlay.astro';

const galleryCategories = await getGalleryCategories();

---




<BaseLayout>
  <ScreenOverlay/>
  <BackgroundSection image={galleryPageConfig.backgroundImage} alt={galleryPageConfig.backgroundAlt} fixedBackground eager>
    <ArchiveLayout>
      <Breadcrumbs items={[{label: 'Gallery'}]}/>
      <ArchivePageHeader
        label="gallery"
        title="Frames &amp; moments"
      >
       Light and time, held in each frame.
      </ArchivePageHeader>

      <GalleryCategoryGrid galleryCategories={galleryCategories}/>

    </ArchiveLayout>
  </BackgroundSection>
</BaseLayout>
