---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BackgroundSection from '@/components/Layout/BackgroundSection.astro';
import Breadcrumbs from '@/components/UI/Breadcrumbs.astro';
import SectionCtaLink from '@/components/UI/SectionCtaLink.astro';

import { aboutPageConfig } from '@/data/about';
import AboutSection from '@/components/About/AboutSection.astro';

import { getAboutPageContent } from '@/sanity/about';
import PageHero from '@/components/UI/PageHero.astro';
import ArchiveLayout from '@/components/Layout/ArchiveLayout.astro';
import ScreenOverlay from '@/components/UI/ScreenOverlay.astro';
import ContactSection from '@/components/Contact/ContactSection.astro';
import AboutAnimationImages from '@/components/About/AboutAnimationImages.astro';

const about = await getAboutPageContent();
---

<BaseLayout>
  <!-- Hero: フルビューポート -->
  <BackgroundSection
    image={aboutPageConfig.backgroundImage}
    alt={aboutPageConfig.backgroundAlt}
    data-scroll-pin
    eager
  >
  <ScreenOverlay/>

  <PageHero
    label="ABOUT"
    title={about?.name}
    tagline={about?.tagline}
  />
  </BackgroundSection>
    <ArchiveLayout extraClass='bg-black' data-about-root>
        <Breadcrumbs items={[{ label: 'About' }]} />

        <AboutAnimationImages/>

        {about?.intro && (
          <AboutSection title="ABOUT">
              {about.intro}
          </AboutSection>
        )}

        {about?.encounterTitle && (
          <AboutSection title={about.encounterTitle}>
              {about.encounterBody}
          </AboutSection>
        )}

        {about?.themeTitle && (
          <AboutSection title={about.themeTitle}>
              {about.themeBody}
          </AboutSection>
        )}

        {about?.achievementsTitle && (
          <AboutSection title={about.achievementsTitle}>
              {about.achievementsIntro}
              {(about.achievementsList ?? []).length > 0 && (
                <ul class="mt-6 space-y-2 pl-4 text-sm leading-relaxed text-white/80 md:text-base">
                    {(about.achievementsList ?? []).map((item) =>
                        <li>{item}</li>
                    )}
                </ul>
              )}
          </AboutSection>
        )}

        <ContactSection
        message={about?.contactMessage}
        email={about?.contactEmail}
        >
        <div class="mt-8">
          <SectionCtaLink href="/contact" label="Contact" hash='contact-form'/>
        </div>
        </ContactSection>

    </div>
  </div>
  </ArchiveLayout>
</BaseLayout>
