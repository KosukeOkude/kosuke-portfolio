---
import Hero from "@/components/Hero/Hero.astro"
import BaseLayout from "@/layouts/BaseLayout.astro"

import WorksTopSection from "@/components/Works/home/WorksTopSection.astro"
import { getAllWorks } from "@/data/works";

import GalleryTopSection from "@/components/Gallery/GalleryTopSection.astro";
import { getGalleryCategories } from "@/data/gallery";
import { displayTopWorks, displayTopGalleryCategories, displayTopAbout, displayTopNews } from '@/sanity/site-settings';

import AboutTopSection from "@/components/About/AboutTopSection.astro";

import NewsTopSection from "@/components/News/NewsTopSection.astro";
import { getAllNews } from '@/data/news';
import Entrance from "@/components/Entrance/Entrance.astro";
import ContactLayout from "@/components/Layout/ContactLayout.astro";
import { ContactForm } from "@/components/Contact/ContactForm";
import ArchiveLayout from "@/components/Layout/ArchiveLayout.astro";



let displayWorksForTop = await displayTopWorks();
if(displayWorksForTop.length === 0){
	const all = await getAllWorks();
	displayWorksForTop = all.slice(0, 6);
}

//トップページのギャラリーの表示数を取得する関数-siteSetting.tsを参照してます
let displayGalleryCategoriesForTop = await displayTopGalleryCategories();
if (displayGalleryCategoriesForTop.length === 0){
    const all = await getGalleryCategories();
    displayGalleryCategoriesForTop = all.slice(0, 6);
}

const displayAboutForTop = await displayTopAbout();

//トップページのギャラリーの表示数を取得する関数-siteSetting.tsを参照してます
let displayNewsForTop= await displayTopNews();
if (displayNewsForTop.length === 0){
    const all = await getAllNews();
    displayNewsForTop = all.slice(0, 6);
}

---

<BaseLayout>
	<Entrance/>
	<Hero/>
	<WorksTopSection works={ displayWorksForTop }/>
	<GalleryTopSection galleryCategories={ displayGalleryCategoriesForTop }/>
	<AboutTopSection about={displayAboutForTop}/>
	<NewsTopSection newsItems={displayNewsForTop}/>
	<ArchiveLayout extraClass="bg-white">
		<ContactLayout>
			<ContactForm client:load/>
		</ContactLayout>
	</ArchiveLayout>
</BaseLayout>
