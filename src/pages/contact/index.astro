---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BackgroundSection from '@/components/Layout/BackgroundSection.astro';
import Breadcrumbs from '@/components/UI/Breadcrumbs.astro';
import { contactPageConfig } from '@/data/contact';
import PageHero from '@/components/UI/PageHero.astro';
import { ContactForm } from '@/components/Contact/ContactForm';
import ArchiveLayout from '@/components/Layout/ArchiveLayout.astro';
import ScreenOverlay from '@/components/UI/ScreenOverlay.astro';
const contactEmail = 'hello@example.com';
const responseNote = '2〜3営業日以内にご返信いたします。';
---


<BaseLayout>
    <BackgroundSection
    image={contactPageConfig.backgroundImage}
    alt={contactPageConfig.backgroundAlt}
  >
  <ScreenOverlay/>
  <PageHero
    label="CONTACT"
    title="お問い合わせ"
    tagline="撮影のご依頼やご相談など、お気軽にご連絡ください。"
  />
  </BackgroundSection>


<ArchiveLayout extraClass='bg-white'>
      <Breadcrumbs tone="on-light" items={[{ label: 'About', href: '/about' }, { label: 'Contact' }]} />
      <section id="contact-form" class="mt-12 md:mt-16 lg:mt-24">
        <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
          <!-- 左: フォーム -->
          <div>

            <ContactForm client:load/>

          </div>
          <!-- 右: メール・返信目安 -->
          <div class="flex flex-col justify-start">
            <h2 class="font-accent text-lg font-bold tracking-wide text-black md:text-xl lg:text-2xl">
              Contact
            </h2>
            <p class="mt-4 text-sm leading-relaxed text-black/70 md:text-base">
              直接メールでのお問い合わせも可能です。
            </p>
            <p class="mt-4 text-sm font-medium text-black/90 md:text-base">
              <a
                href={`mailto:${contactEmail}`}
                class="underline underline-offset-4 hover:text-black"
              >
                {contactEmail}
              </a>
            </p>
            <p class="mt-6 text-xs text-black/50 md:text-sm">
              {responseNote}
            </p>
          </div>
        </div>
      </section>
</ArchiveLayout>
</BaseLayout>
