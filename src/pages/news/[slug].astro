---
import Breadcrumbs from "@/components/UI/Breadcrumbs.astro";
import BaseLayout from '@/layouts/BaseLayout.astro';
import LabeledSection from "@/components/UI/LabeledSection.astro";
import DetailPageLayout from "@/components/Layout/DetailPageLayout.astro";
import PageBottomNav from "@/components/UI/PageBottomNav.astro";
import DetailPagePrevNextNav from '@/components/UI/DetailPagePrevNextNav.astro';
import DetailImageGalleryWithLightbox from "@/components/Lightbox/DetailImageGalleryWithLightbox";
import { getAllNews, getNewsBySlug, newsPageConfig } from '@/data/news';
import BackgroundSection from '@/components/Layout/BackgroundSection.astro';
import { normalizeSlug } from "@/utils";
import YoutubeVideos from "@/components/UI/YoutubeVideos.astro";




export const getStaticPaths = (async () => {
    const allNews = await getAllNews();
    return allNews.map((newsItem) => ({
        params: {slug: normalizeSlug(newsItem.slug)}
    }))
});


const { slug } = Astro.params;
const newsItem = await getNewsBySlug(slug ?? '');
if(!newsItem){
    throw new Error(`News not found for slug: ${slug}`);
}
const allNews = await getAllNews();
const currentIndex = allNews.findIndex((item) => slug === normalizeSlug(item.slug))
const prevItem = allNews[currentIndex - 1];
const nextItem = allNews[currentIndex + 1];
---




<BaseLayout>
  <BackgroundSection mobileImage={newsPageConfig.mobileBackgroundImage} image={newsPageConfig.backgroundImage} alt={newsPageConfig.backgroundAlt} fixedBackground eager overlayClass="bg-black/50" mobileBlack>
  <DetailPageLayout>
        <Breadcrumbs items={[{ label: 'News', href: '/news' },{ label: newsItem.title },]}/>

        <DetailImageGalleryWithLightbox
          mainImageUrl={newsItem.thumbnailUrl}
          mainImageLightboxUrl={newsItem.thumbnailLightboxUrl}
          mainImageAlt={newsItem.thumbnailAlt}
          subImages={newsItem.subImage ?? []}
          client:load
        >
        <YoutubeVideos
        videos={newsItem.videos}
      />
          <!-- A案② タイトル・日付・タグ -->
          <header class="space-y-4">
            <p class="text-[10px] md:text-xs uppercase tracking-[0.25em] text-white/50">
              News
            </p>
            <h1
              class="font-accent font-semibold text-xl md:text-2xl lg:text-[26px] leading-snug text-white"
            >
              {newsItem.title}
            </h1>
            <p class="text-[11px] md:text-xs tracking-[0.16em] uppercase text-white/60">
              {newsItem.date}
              {newsItem.category && (
                <>
                  {' '}
                  ・ {newsItem.category}
                </>
              )}
            </p>
            {newsItem.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {newsItem.tags.map((tag) => (
                  <span class="text-[10px] md:text-xs px-3 py-1 rounded-full border border-white/25 bg-white/10">
                    #{tag}
                  </span>
                ))}
              </div>
            )}
          </header>
          <!-- A案③ リード（説明） -->
          {newsItem.description && (
            <p class="text-sm md:text-base text-white/80 leading-relaxed max-w-3xl">
              {newsItem.description}
            </p>
          )}
          <!-- A案④ 本文・詳細ブロック -->
          <section class="space-y-10 text-sm md:text-base leading-relaxed">
            {newsItem.body && (
              <LabeledSection label="本文">
                <p class="text-white/80 whitespace-pre-line">{newsItem.body}</p>
              </LabeledSection>
            )}
            {newsItem.details && (
              <LabeledSection label="詳細">
                <p class="text-white/80 whitespace-pre-line">{newsItem.details}</p>
              </LabeledSection>
            )}
            {newsItem.venue && (
              <LabeledSection label="会場">
                <p class="text-white/80">{newsItem.venue}</p>
              </LabeledSection>
            )}
            {newsItem.eventDate && (
              <LabeledSection label="日時">
                <p class="text-white/80">{newsItem.eventDate}</p>
              </LabeledSection>
            )}
            {newsItem.relatedLinks && newsItem.relatedLinks.length > 0 && (
              <LabeledSection label="関連リンク">
                <ul class="text-white/80 space-y-2">
                  {newsItem.relatedLinks.map((link) => (
                    <li>
                      <a
                        href={link.url}
                        class="underline underline-offset-2 hover:text-white"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </LabeledSection>
            )}
          </section>
        </DetailImageGalleryWithLightbox>
        <DetailPagePrevNextNav prevItem={prevItem} nextItem={nextItem} basePath="news"/>
        <PageBottomNav label="news" href="/news" />
      </DetailPageLayout>
  </BackgroundSection>
  </BaseLayout>