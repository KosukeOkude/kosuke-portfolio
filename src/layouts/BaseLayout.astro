---
import '@/styles/global.css';
import Header from '@/components/Layout/Header.astro';
import Footer from '@/components/Layout/Footer.astro';

---

<html lang="ja" data-decor-cursor="orbit">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon-png.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>Kosuke's Photo Portfolio</title>
  </head>
  <body class="bg-black">
    <Header />
    <main class="max-w-[2400px] mx-auto">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  import "@/client";
  import "@/gsap/initGsapClient";
</script>

<script is:inline>
  // インアプリブラウザ（Instagram/LINE）対応:
  // window.innerHeight をCSS変数に固定し、ツールバー出現によるレイアウトシフトを防ぐ
  (function () {
    var h = window.innerHeight;
    document.documentElement.style.setProperty("--actual-vh", h + "px");

    window.addEventListener("resize", function () {
      var newH = window.innerHeight;
      // ツールバー出入り（小さい変化）は無視し、向き変更（大きい変化）のみ更新
      if (Math.abs(newH - h) > 100) {
        h = newH;
        document.documentElement.style.setProperty("--actual-vh", h + "px");
      }
    });
  })();
</script>